# 1. Ignore everything by default
/*

# 2. Re-allow directories we want to track
!R/
!data/
!scripts/
!.claude/

# 3. Inside R/ and data/, track everything
!R/**
!data/**
!scripts/**
!.claude/**
!*.qmd
!CLAUDE.md

# 4. Ignore R / IDE / session artifacts everywhere
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# 5. Ignore rendered outputs
*.html

